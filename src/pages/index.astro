---
import Layout from '../layouts/Layout.astro'
import { getBookPage, urlFor } from '../lib/sanity'

const page = await getBookPage()

const bookTitle = page?.bookTitle || 'Rugeshi Hill, Where Humanity Was Buried'
const bookSubtitle = page?.bookSubtitle || 'A Memoir of Survival, Memory, and the Unburied Truth'
const authorName = page?.authorName || 'Apollinaire Munyaneza'
const authorTitle = page?.authorTitle || 'Genocide Survivor · Author · Witness'
const witnessHeadline = page?.witnessHeadline || 'A Witness to History'
const witnessLeft = page?.witnessTextLeft || 'On the hills of Rugeshi, amid the beauty of Rwanda\'s landscape, one of humanity\'s darkest chapters unfolded. Apollinaire Munyaneza was there — a child forced to witness the impossible, to survive the unsurvivable.'
const witnessRight = page?.witnessTextRight || 'This memoir is not only a record of atrocity. It is a testament to the resilience of memory, the duty of witness, and the long, unfinished work of healing that follows catastrophe.'
const pullQuote = page?.pullQuote || 'The hill did not forget. Neither could I. To speak is not to wound again — it is to refuse that the dead were never there.'
const ctaHeadline = page?.ctaHeadline || 'Read This Important Memoir'
const ctaBuyLink = page?.ctaBuyLink || '#'
const ctaLearnLink = page?.ctaLearnLink || '#'
const themes = page?.themes || [
  { title: 'Loss & Memory', description: 'The devastating impact of the Genocide on one family — both parents, a brother, five sisters, and hundreds of extended family members on Rugeshi Hill.' },
  { title: 'Truth & Evidence', description: 'Evidence that the Genocide was not a spontaneous eruption of anger, but a meticulously planned, state-orchestrated atrocity that began years before 1994.' },
  { title: 'Resilience & Purpose', description: 'How a survivor found the strength to rebuild his life, honouring those who perished by living with purpose and rising beyond the ordinary.' },
]

const bookCoverUrl = page?.bookCover ? urlFor(page.bookCover).url() : '/images/book-cover.png'
const authorPhotoUrl = page?.authorPhoto ? urlFor(page.authorPhoto).url() : '/images/author-photo.png'
---

<Layout title={bookTitle}>

  <!-- NAV -->
  <nav class="w-full bg-[#1A1208] px-6 md:px-20 py-5 flex items-center justify-between fixed top-0 z-50">
    <span class="font-['Cormorant_Garamond'] text-[#C4A97D] text-lg md:text-xl font-semibold tracking-wide">Rugeshi Hill</span>
    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-10">
      <a href="#witness" class="font-['Inter'] text-[#F5F0E8] text-sm tracking-wide hover:text-[#C4A97D] transition-colors">About</a>
      <a href="#author" class="font-['Inter'] text-[#F5F0E8] text-sm tracking-wide hover:text-[#C4A97D] transition-colors">Author</a>
      <a href="/gallery" class="font-['Inter'] text-[#F5F0E8] text-sm tracking-wide hover:text-[#C4A97D] transition-colors">Gallery</a>
      <a href="#themes" class="font-['Inter'] text-[#F5F0E8] text-sm tracking-wide hover:text-[#C4A97D] transition-colors">The Book</a>
      <a href={ctaBuyLink} class="font-['Inter'] bg-[#C4A97D] text-[#1A1208] text-xs font-semibold px-6 py-2.5 tracking-wide hover:bg-[#8B7355] hover:text-white transition-colors">Order Now</a>
    </div>
    <!-- Mobile: just the CTA button -->
    <a href={ctaBuyLink} class="md:hidden font-['Inter'] bg-[#C4A97D] text-[#1A1208] text-xs font-semibold px-4 py-2 hover:bg-[#8B7355] transition-colors">Get the Book</a>
  </nav>

  <!-- HERO -->
  <section class="w-full min-h-[600px] md:h-[700px] pt-[76px] relative overflow-hidden flex items-center">
    <div class="absolute inset-0">
      <img src="/images/rugeshi-landscape.png" alt="" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-[#1A1208]/70"></div>
    </div>
    <div class="relative z-20 w-full max-w-[1440px] mx-auto px-6 md:px-20 py-12 md:py-0 flex flex-col md:flex-row items-center justify-between gap-10">
      <div class="max-w-full md:max-w-[580px] text-center md:text-left">
        <p class="font-['Inter'] text-[#C4A97D] text-xs md:text-sm font-medium tracking-[0.15em] uppercase mb-4 md:mb-6">A Memoir · 1994 Genocide Against the Tutsi</p>
        <h1 class="font-['Cormorant_Garamond'] text-[#F5F0E8] text-[36px] md:text-[56px] leading-[1.1] font-semibold mb-4 md:mb-6">{bookTitle}</h1>
        <div class="w-16 h-[2px] bg-[#C4A97D] mb-4 md:mb-6 mx-auto md:mx-0"></div>
        <p class="font-['Inter'] text-[#D4C9B8] text-base md:text-lg leading-relaxed mb-6 md:mb-10">{bookSubtitle}</p>
        <p class="font-['Cormorant_Garamond'] text-[#C4A97D] text-lg md:text-xl italic">By {authorName}</p>
      </div>
      <div
        id="book-zoom"
        class="flex-shrink-0 w-[240px] h-[320px] md:w-[500px] md:h-[400px] shadow-2xl relative cursor-zoom-in overflow-hidden"
      >
        <img
          id="book-cover-img"
          src={bookCoverUrl}
          alt={bookTitle}
          class="w-full h-full object-cover transition-transform duration-100 ease-out"
          style="transform-origin: 0 0;"
        />
        <div id="zoom-hint" class="absolute bottom-3 right-3 bg-[#1A1208]/70 text-[#C4A97D] text-[10px] font-['Inter'] tracking-widest uppercase px-2 py-1 transition-opacity duration-300">
          Hover to zoom
        </div>
      </div>
    </div>
  </section>

  <!-- WITNESS TO HISTORY -->
  <section id="witness" class="w-full bg-[#F5F0E8] py-16 md:py-24">
    <div class="max-w-[1440px] mx-auto px-6 md:px-20">
      <p class="font-['Inter'] text-[#8A7E6E] text-sm tracking-[0.15em] uppercase text-center mb-6">The Book</p>
      <h2 class="font-['Cormorant_Garamond'] text-[#1A1208] text-[32px] md:text-[44px] font-semibold text-center leading-tight mb-4">{witnessHeadline}</h2>
      <div class="w-16 h-[2px] bg-[#C4A97D] mx-auto mb-10 md:mb-12"></div>

      <!-- Two-column layout: slider + text -->
      <div class="flex flex-col md:flex-row md:items-start gap-0 md:gap-12">

        <!-- LEFT: Side slider + caption -->
        <div class="w-full md:w-[480px] flex-shrink-0">
          <div class="relative h-[280px] md:h-[560px] overflow-hidden" id="witness-slider">
            <div id="witness-slides" class="flex h-full transition-transform duration-500 ease-in-out">
              {(page?.galleryImages?.length > 0 ? page.galleryImages : null)
                ? page.galleryImages.map((img: any) => (
                    <div class="min-w-full h-full flex-shrink-0 relative" data-caption={img?.caption || ''}>
                      <img src={urlFor(img.image ?? img).url()} alt="" class="w-full h-full object-cover" />
                      <div class="absolute bottom-0 left-0 right-0 z-10 bg-gradient-to-t from-[#1A1208]/80 to-transparent px-5 pb-9 pt-10">
                        {img?.title && <p class="font-['Cormorant_Garamond'] text-[#F5F0E8] text-lg italic leading-snug">{img.title}</p>}
                        {img?.category && <p class="font-['Inter'] text-[#C4A97D] text-[11px] font-medium tracking-[0.15em] uppercase mt-1">{img.category}</p>}
                      </div>
                    </div>
                  ))
                : (
                  <div class="min-w-full h-full flex-shrink-0 relative">
                    <img src="/images/rugeshi-landscape.png" alt="The hills of Rugeshi" class="w-full h-full object-cover" />
                    <div class="absolute bottom-0 left-0 right-0 z-10 bg-gradient-to-t from-[#1A1208]/60 to-transparent px-5 pb-9 pt-10"></div>
                  </div>
                )
              }
            </div>
            <!-- Always-visible arrows -->
            <button id="witness-prev" class="absolute left-3 top-1/2 -translate-y-1/2 z-20 bg-[#1A1208]/70 hover:bg-[#1A1208] text-[#C4A97D] w-10 h-10 flex items-center justify-center transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button id="witness-next" class="absolute right-3 top-1/2 -translate-y-1/2 z-20 bg-[#1A1208]/70 hover:bg-[#1A1208] text-[#C4A97D] w-10 h-10 flex items-center justify-center transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </button>
            <div id="witness-dots" class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2 z-20"></div>
          </div>
          <!-- Caption — outside overflow-hidden, updates with slider -->
          <p id="witness-caption" class="font-['Inter'] text-[#8A7E6E] text-sm italic text-center mt-3 min-h-[20px]"></p>
        </div>

        <!-- RIGHT: Text column -->
        <div class="flex-1 space-y-6 pt-8 md:pt-0">
          <p class="font-['Inter'] text-[#1A1208] text-base leading-[1.9]">{witnessLeft}</p>
          <p class="font-['Inter'] text-[#1A1208] text-base leading-[1.9]">{witnessRight}</p>
          <p class="font-['Inter'] text-[#1A1208] text-base leading-[1.9]">During the period between April and July 1994, Apollinaire's family endured targeted violence amounting to the acts of Genocide since 1990, largely because the Western Province was home to key architects of the Genocide — civilians as well as high-ranking military officials.</p>
          <p class="font-['Inter'] text-[#1A1208] text-base leading-[1.9]">Today, the hills of Rugeshi stand as silent witnesses to what transpired. For Apollinaire, writing this memoir was not only an act of personal reckoning — it was a moral imperative. The world must know. The truth must endure.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- AUTHOR -->
  <section id="author" class="w-full bg-[#1A1208] py-16 md:py-24">
    <div class="max-w-[1440px] mx-auto px-6 md:px-20 flex flex-col md:flex-row items-start gap-10 md:gap-20">
      <div class="pt-0 md:pt-6 max-w-full md:max-w-[740px]">
        <p class="font-['Inter'] text-[#8A7E6E] text-sm tracking-[0.15em] uppercase mb-5">The Author</p>
        <h2 class="font-['Cormorant_Garamond'] text-[#F5F0E8] text-[32px] md:text-[40px] font-semibold leading-tight mb-8">{authorName}</h2>
        <div class="font-['Inter'] text-[#D4C9B8] text-base leading-[1.9] space-y-5">
          {page?.authorBio ? (
            page.authorBio.map((block: any) => (
              <p>{block.children?.map((c: any) => c.text).join('')}</p>
            ))
          ) : (
            <>
              <p>Apollinaire Munyaneza was born and raised in Nyabihu District (formerly Nkuli Commune) in Rwanda's Western Province in a loving and harmonious family.</p>
              <p>Despite surviving the horrors of genocide, Apollinaire found the strength to rebuild his life with resilience. For him, survival is not just a reminder of how humanity can be lost under bad leadership — it is also a responsibility.</p>
            </>
          )}
        </div>
        <div class="border-l-2 border-[#C4A97D] pl-6 mt-8">
          <p class="font-['Cormorant_Garamond'] text-[#C4A97D] text-xl italic leading-relaxed">
            "{page?.authorQuote || 'To truly honor those who perished, survivors must strive to live with purpose and rise beyond the ordinary.'}"
          </p>
        </div>
      </div>
      <div class="flex-shrink-0 w-full md:w-[380px] h-[300px] md:h-[460px] overflow-hidden order-first md:order-none">
        <img src={authorPhotoUrl} alt={authorName} class="w-full h-full object-cover object-top" />
      </div>
    </div>
  </section>

  <!-- KEY THEMES -->
  <section id="themes" class="w-full bg-[#F5F0E8] py-16 md:py-24">
    <div class="max-w-[1440px] mx-auto px-6 md:px-20">
      <p class="font-['Inter'] text-[#8A7E6E] text-sm tracking-[0.15em] uppercase text-center mb-6">What you'll discover</p>
      <h2 class="font-['Cormorant_Garamond'] text-[#1A1208] text-[32px] md:text-[44px] font-semibold text-center leading-tight mb-4">Key Themes</h2>
      <div class="w-16 h-[2px] bg-[#C4A97D] mx-auto mb-10 md:mb-16"></div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {themes.map((theme: any, i: number) => (
          <div class="bg-[#EDE8DF] p-8 md:p-10">
            <p class="font-['Cormorant_Garamond'] text-[#C4A97D] text-[40px] font-semibold mb-4 leading-none">
              {String(i + 1).padStart(2, '0')}
            </p>
            <h3 class="font-['Cormorant_Garamond'] text-[#1A1208] text-2xl font-semibold italic mb-4">{theme.title}</h3>
            <p class="font-['Inter'] text-[#8A7E6E] text-sm leading-[1.9]">{theme.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PULL QUOTE -->
  <section class="w-full relative min-h-[400px] md:h-[500px] flex items-center justify-center overflow-hidden py-16 md:py-0">
    <div class="absolute inset-0">
      <img src="/images/rugeshi-landscape.png" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-[#1A1208]/30"></div>
    </div>
    <div class="relative z-10 w-full max-w-[860px] mx-auto px-6 md:px-8">
      <div class="bg-[#1A1208]/80 px-8 md:px-16 py-10 md:py-14 text-center">
        <p class="font-['Cormorant_Garamond'] text-[#C4A97D] text-[48px] md:text-[64px] leading-none mb-2">"</p>
        <p class="font-['Cormorant_Garamond'] text-[#F5F0E8] text-[20px] md:text-[26px] italic leading-[1.7] mb-8 md:mb-10">{pullQuote}</p>
        <div class="flex items-center justify-center gap-4">
          <div class="w-8 md:w-12 h-[1px] bg-[#C4A97D]"></div>
          <p class="font-['Inter'] text-[#C4A97D] text-xs tracking-[0.2em] uppercase">{authorName}</p>
          <div class="w-8 md:w-12 h-[1px] bg-[#C4A97D]"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="w-full bg-[#F5F0E8] py-16 md:py-24">
    <div class="max-w-[1440px] mx-auto px-6 md:px-20 text-center">
      <p class="font-['Inter'] text-[#8A7E6E] text-sm tracking-[0.15em] uppercase mb-6">Get Your Copy</p>
      <h2 class="font-['Cormorant_Garamond'] text-[#1A1208] text-[32px] md:text-[44px] font-semibold text-center leading-tight mb-6">{ctaHeadline}</h2>
      <p class="font-['Inter'] text-[#8A7E6E] text-base max-w-[500px] mx-auto leading-[1.9] mb-10 md:mb-12">A story that must be told. A history that must never be forgotten.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-6">
        <a href={ctaBuyLink} class="w-full sm:w-auto font-['Inter'] bg-[#1A1208] text-[#F5F0E8] text-sm font-semibold px-10 py-4 hover:bg-[#2C2015] transition-colors text-center">Order Now</a>
        <a href={ctaLearnLink} class="w-full sm:w-auto font-['Inter'] border border-[#1A1208] text-[#1A1208] text-sm font-semibold px-10 py-4 hover:bg-[#1A1208] hover:text-[#F5F0E8] transition-colors text-center">Learn More</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="w-full bg-[#1A1208] py-16">
    <div class="max-w-[1440px] mx-auto px-6 md:px-20">
      <div class="flex flex-col md:flex-row items-start justify-between pb-10 border-b border-[#3D3020] gap-10 md:gap-0">
        <div class="max-w-full md:max-w-[400px]">
          <p class="font-['Cormorant_Garamond'] text-[#C4A97D] text-2xl font-semibold mb-2">Rugeshi Hill</p>
          <p class="font-['Inter'] text-[#8A7E6E] text-sm mb-6">Where Humanity Was Buried</p>
          <p class="font-['Inter'] text-[#8A7E6E] text-sm leading-[1.9]">A memoir by Apollinaire Munyaneza that bears witness to one of history's darkest hours, and to the enduring strength of the human spirit.</p>
        </div>
        <div class="flex gap-12 md:gap-20">
          <div>
            <p class="font-['Inter'] text-[#F5F0E8] text-xs font-semibold tracking-widest uppercase mb-6">Navigate</p>
            <div class="space-y-4">
              <a href="#witness" class="block font-['Inter'] text-[#8A7E6E] text-sm hover:text-[#C4A97D] transition-colors">About the Book</a>
              <a href="#author" class="block font-['Inter'] text-[#8A7E6E] text-sm hover:text-[#C4A97D] transition-colors">The Author</a>
              <a href="#themes" class="block font-['Inter'] text-[#8A7E6E] text-sm hover:text-[#C4A97D] transition-colors">Key Themes</a>
              <a href={ctaBuyLink} class="block font-['Inter'] text-[#8A7E6E] text-sm hover:text-[#C4A97D] transition-colors">Order Now</a>
            </div>
          </div>
          <div>
            <p class="font-['Inter'] text-[#F5F0E8] text-xs font-semibold tracking-widest uppercase mb-6">Connect</p>
            <div class="space-y-4">
              <a href="mailto:contact@rugeshihill.com" class="block font-['Inter'] text-[#8A7E6E] text-sm hover:text-[#C4A97D] transition-colors">Contact Author</a>
              <a href="mailto:press@rugeshihill.com" class="block font-['Inter'] text-[#8A7E6E] text-sm hover:text-[#C4A97D] transition-colors">Press Inquiries</a>
              <a href="mailto:speaking@rugeshihill.com" class="block font-['Inter'] text-[#8A7E6E] text-sm hover:text-[#C4A97D] transition-colors">Speaking Events</a>
              <a href="/gallery" class="block font-['Inter'] text-[#C4A97D] text-sm hover:text-[#8B7355] transition-colors">View our Gallery</a>
            </div>
          </div>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between pt-8 gap-2">
        <p class="font-['Inter'] text-[#8A7E6E] text-xs">© 2026 Apollinaire Munyaneza. All rights reserved.</p>
        <p class="font-['Inter'] text-[#8A7E6E] text-xs">Published by Inzozi Publishers</p>
      </div>
    </div>
  </footer>

</Layout>

<script>
  // Book zoom
  const container = document.getElementById('book-zoom');
  const img = document.getElementById('book-cover-img') as HTMLImageElement;
  const hint = document.getElementById('zoom-hint');
  const SCALE = 2.5;

  if (container && img) {
    container.addEventListener('mouseenter', () => {
      img.style.transition = 'transform 0.15s ease-out';
      if (hint) hint.style.opacity = '0';
    });
    container.addEventListener('mouseleave', () => {
      img.style.transition = 'transform 0.3s ease-out';
      img.style.transform = 'scale(1) translate(0px, 0px)';
      if (hint) hint.style.opacity = '1';
    });
    container.addEventListener('mousemove', (e) => {
      const rect = container.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const xPercent = x / rect.width;
      const yPercent = y / rect.height;
      const translateX = -xPercent * rect.width * (SCALE - 1);
      const translateY = -yPercent * rect.height * (SCALE - 1);
      img.style.transform = `scale(${SCALE}) translate(${translateX / SCALE}px, ${translateY / SCALE}px)`;
    });
  }

  // Witness slider
  const witnessSlides = document.getElementById('witness-slides') as HTMLElement;
  const witnessDotsContainer = document.getElementById('witness-dots');
  const witnessPrev = document.getElementById('witness-prev');
  const witnessNext = document.getElementById('witness-next');
  const witnessCaption = document.getElementById('witness-caption');

  if (witnessSlides) {
    const total = witnessSlides.children.length;
    let current = 0;

    for (let i = 0; i < total; i++) {
      const dot = document.createElement('button');
      dot.className = `w-2 h-2 rounded-full transition-all ${i === 0 ? 'bg-[#C4A97D] w-4' : 'bg-white/60'}`;
      dot.addEventListener('click', () => goTo(i));
      witnessDotsContainer?.appendChild(dot);
    }

    function updateDots() {
      witnessDotsContainer?.querySelectorAll('button').forEach((dot, i) => {
        dot.className = `w-2 h-2 rounded-full transition-all ${i === current ? 'bg-[#C4A97D] w-4' : 'bg-white/60'}`;
      });
    }

    function goTo(index: number) {
      current = (index + total) % total;
      witnessSlides.style.transform = `translateX(-${current * 100}%)`;
      updateDots();
      if (witnessCaption) {
        const slide = witnessSlides.children[current] as HTMLElement;
        witnessCaption.textContent = slide?.dataset.caption || '';
      }
    }

    witnessPrev?.addEventListener('click', () => goTo(current - 1));
    witnessNext?.addEventListener('click', () => goTo(current + 1));
    setInterval(() => goTo(current + 1), 5000);
  }
</script>